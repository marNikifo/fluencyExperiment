        <Param val="Use your keyboard to answer the following question:&amp;#10;&amp;#10;What will you rate afterwards?&amp;#10;&amp;#10;a) the face, based on familiarity&amp;#10;&amp;#10;b) this experiment, based on excitement&amp;#10;&amp;#10;c) the face, based on attractiveness" valType="str" updates="constant" name="text"/>
